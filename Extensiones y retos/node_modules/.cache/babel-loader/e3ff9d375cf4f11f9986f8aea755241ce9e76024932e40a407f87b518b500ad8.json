{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport { Modal } from 'bootstrap';\nconst API = 'https://6a1aebbbbc2f94475492cebb.mockapi.io/Productos';\nexport default {\n  data() {\n    return {\n      productos: [],\n      form: {\n        nombre: '',\n        precio: ''\n      },\n      editando: null,\n      modal: null\n    };\n  },\n  async created() {\n    const res = await fetch(API);\n    this.productos = await res.json();\n  },\n  mounted() {\n    this.modal = new Modal(document.getElementById('productoModal'));\n  },\n  methods: {\n    abrirModal(producto = null) {\n      if (producto) {\n        this.editando = producto.id;\n        this.form = {\n          nombre: producto.nombre,\n          precio: producto.precio\n        };\n      } else {\n        this.editando = null;\n        this.form = {\n          nombre: '',\n          precio: ''\n        };\n      }\n      this.modal.show();\n    },\n    async guardar() {\n      if (!this.form.nombre || !this.form.precio) return;\n      if (this.editando) {\n        const res = await fetch(`${API}/${this.editando}`, {\n          method: 'PUT',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify(this.form)\n        });\n        const actualizado = await res.json();\n        const index = this.productos.findIndex(p => p.id === this.editando);\n        this.productos[index] = actualizado;\n      } else {\n        const res = await fetch(API, {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify(this.form)\n        });\n        const nuevo = await res.json();\n        this.productos.push(nuevo);\n      }\n      this.modal.hide();\n      this.form = {\n        nombre: '',\n        precio: ''\n      };\n      this.editando = null;\n    },\n    async eliminar(id) {\n      await fetch(`${API}/${id}`, {\n        method: 'DELETE'\n      });\n      this.productos = this.productos.filter(p => p.id !== id);\n    }\n  }\n};","map":{"version":3,"names":["Modal","API","data","productos","form","nombre","precio","editando","modal","created","res","fetch","json","mounted","document","getElementById","methods","abrirModal","producto","id","show","guardar","method","headers","body","JSON","stringify","actualizado","index","findIndex","p","nuevo","push","hide","eliminar","filter"],"sources":["C:\\Users\\SCIS-PC18\\Desktop\\DAWYSO-A\\Extensiones y retos\\src\\components\\ProductoComponent.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-4\">\r\n    <h3>Gestión de Productos</h3>\r\n\r\n    <button class=\"btn btn-success mb-3\" @click=\"abrirModal()\">+ Agregar Producto</button>\r\n\r\n    <table class=\"table table-striped\">\r\n      <thead>\r\n        <tr><th>Nombre</th><th>Precio</th><th>Acciones</th></tr>\r\n      </thead>\r\n      <tbody>\r\n        <tr v-for=\"p in productos\" :key=\"p.id\">\r\n          <td>{{ p.nombre }}</td>\r\n          <td>{{ p.precio }}</td>\r\n          <td>\r\n            <button @click=\"abrirModal(p)\" class=\"btn btn-warning btn-sm me-2\">Editar</button>\r\n            <button @click=\"eliminar(p.id)\" class=\"btn btn-danger btn-sm\">Eliminar</button>\r\n          </td>\r\n        </tr>\r\n      </tbody>\r\n    </table>\r\n\r\n    <!-- Modal -->\r\n    <div class=\"modal fade\" id=\"productoModal\" tabindex=\"-1\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">{{ editando ? 'Editar Producto' : 'Nuevo Producto' }}</h5>\r\n            <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <input v-model=\"form.nombre\" class=\"form-control mb-2\" placeholder=\"Nombre\" />\r\n            <input v-model=\"form.precio\" class=\"form-control mb-2\" placeholder=\"Precio\" type=\"number\" />\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" @click=\"guardar\">Guardar</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Modal } from 'bootstrap'\r\n\r\nconst API = 'https://6a1aebbbbc2f94475492cebb.mockapi.io/Productos'\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      productos: [],\r\n      form: { nombre: '', precio: '' },\r\n      editando: null,\r\n      modal: null\r\n    }\r\n  },\r\n  async created() {\r\n    const res = await fetch(API)\r\n    this.productos = await res.json()\r\n  },\r\n  mounted() {\r\n    this.modal = new Modal(document.getElementById('productoModal'))\r\n  },\r\n  methods: {\r\n    abrirModal(producto = null) {\r\n      if (producto) {\r\n        this.editando = producto.id\r\n        this.form = { nombre: producto.nombre, precio: producto.precio }\r\n      } else {\r\n        this.editando = null\r\n        this.form = { nombre: '', precio: '' }\r\n      }\r\n      this.modal.show()\r\n    },\r\n    async guardar() {\r\n      if (!this.form.nombre || !this.form.precio) return\r\n\r\n      if (this.editando) {\r\n        const res = await fetch(`${API}/${this.editando}`, {\r\n          method: 'PUT',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify(this.form)\r\n        })\r\n        const actualizado = await res.json()\r\n        const index = this.productos.findIndex(p => p.id === this.editando)\r\n        this.productos[index] = actualizado\r\n      } else {\r\n        const res = await fetch(API, {\r\n          method: 'POST',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify(this.form)\r\n        })\r\n        const nuevo = await res.json()\r\n        this.productos.push(nuevo)\r\n      }\r\n\r\n      this.modal.hide()\r\n      this.form = { nombre: '', precio: '' }\r\n      this.editando = null\r\n    },\r\n    async eliminar(id) {\r\n      await fetch(`${API}/${id}`, { method: 'DELETE' })\r\n      this.productos = this.productos.filter(p => p.id !== id)\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AA8CA,SAASA,KAAI,QAAS,WAAU;AAEhC,MAAMC,GAAE,GAAI,uDAAsD;AAElE,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE;QAAEC,MAAM,EAAE,EAAE;QAAEC,MAAM,EAAE;MAAG,CAAC;MAChCC,QAAQ,EAAE,IAAI;MACdC,KAAK,EAAE;IACT;EACF,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAMC,GAAE,GAAI,MAAMC,KAAK,CAACV,GAAG;IAC3B,IAAI,CAACE,SAAQ,GAAI,MAAMO,GAAG,CAACE,IAAI,CAAC;EAClC,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACL,KAAI,GAAI,IAAIR,KAAK,CAACc,QAAQ,CAACC,cAAc,CAAC,eAAe,CAAC;EACjE,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAACC,QAAO,GAAI,IAAI,EAAE;MAC1B,IAAIA,QAAQ,EAAE;QACZ,IAAI,CAACX,QAAO,GAAIW,QAAQ,CAACC,EAAC;QAC1B,IAAI,CAACf,IAAG,GAAI;UAAEC,MAAM,EAAEa,QAAQ,CAACb,MAAM;UAAEC,MAAM,EAAEY,QAAQ,CAACZ;QAAO;MACjE,OAAO;QACL,IAAI,CAACC,QAAO,GAAI,IAAG;QACnB,IAAI,CAACH,IAAG,GAAI;UAAEC,MAAM,EAAE,EAAE;UAAEC,MAAM,EAAE;QAAG;MACvC;MACA,IAAI,CAACE,KAAK,CAACY,IAAI,CAAC;IAClB,CAAC;IACD,MAAMC,OAAOA,CAAA,EAAG;MACd,IAAI,CAAC,IAAI,CAACjB,IAAI,CAACC,MAAK,IAAK,CAAC,IAAI,CAACD,IAAI,CAACE,MAAM,EAAE;MAE5C,IAAI,IAAI,CAACC,QAAQ,EAAE;QACjB,MAAMG,GAAE,GAAI,MAAMC,KAAK,CAAC,GAAGV,GAAG,IAAI,IAAI,CAACM,QAAQ,EAAE,EAAE;UACjDe,MAAM,EAAE,KAAK;UACbC,OAAO,EAAE;YAAE,cAAc,EAAE;UAAmB,CAAC;UAC/CC,IAAI,EAAEC,IAAI,CAACC,SAAS,CAAC,IAAI,CAACtB,IAAI;QAChC,CAAC;QACD,MAAMuB,WAAU,GAAI,MAAMjB,GAAG,CAACE,IAAI,CAAC;QACnC,MAAMgB,KAAI,GAAI,IAAI,CAACzB,SAAS,CAAC0B,SAAS,CAACC,CAAA,IAAKA,CAAC,CAACX,EAAC,KAAM,IAAI,CAACZ,QAAQ;QAClE,IAAI,CAACJ,SAAS,CAACyB,KAAK,IAAID,WAAU;MACpC,OAAO;QACL,MAAMjB,GAAE,GAAI,MAAMC,KAAK,CAACV,GAAG,EAAE;UAC3BqB,MAAM,EAAE,MAAM;UACdC,OAAO,EAAE;YAAE,cAAc,EAAE;UAAmB,CAAC;U