{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport { Modal } from 'bootstrap';\nimport { defineRule, validate } from 'vee-validate';\ndefineRule('required', value => {\n  if (!value || !value.toString().trim()) return 'Este campo es obligatorio';\n  return true;\n});\ndefineRule('minPrice', value => {\n  if (value <= 0) return 'El precio debe ser mayor a 0';\n  return true;\n});\nconst API = 'https://6a1aebbbbc2f94475492cebb.mockapi.io/Productos';\nexport default {\n  data() {\n    return {\n      productos: [],\n      form: {\n        nombre: '',\n        precio: ''\n      },\n      errores: {\n        nombre: '',\n        precio: ''\n      },\n      editando: null,\n      modal: null\n    };\n  },\n  async created() {\n    const res = await fetch(API);\n    this.productos = await res.json();\n  },\n  mounted() {\n    this.modal = new Modal(document.getElementById('productoModal'));\n  },\n  methods: {\n    abrirModal(producto = null) {\n      if (producto) {\n        this.editando = producto.id;\n        this.form = {\n          nombre: producto.nombre,\n          precio: producto.precio\n        };\n      } else {\n        this.editando = null;\n        this.form = {\n          nombre: '',\n          precio: ''\n        };\n      }\n      this.errores = {\n        nombre: '',\n        precio: ''\n      };\n      this.modal.show();\n    },\n    async guardar() {\n      const resultNombre = await validate(this.form.nombre, 'required');\n      const resultPrecio = await validate(this.form.precio, 'required|minPrice');\n      this.errores.nombre = resultNombre.valid ? '' : resultNombre.errors[0];\n      this.errores.precio = resultPrecio.valid ? '' : resultPrecio.errors[0];\n      if (!resultNombre.valid || !resultPrecio.valid) return;\n      if (this.editando) {\n        const res = await fetch(`${API}/${this.editando}`, {\n          method: 'PUT',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify(this.form)\n        });\n        const actualizado = await res.json();\n        const index = this.productos.findIndex(p => p.id === this.editando);\n        this.productos[index] = actualizado;\n      } else {\n        const res = await fetch(API, {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify(this.form)\n        });\n        const nuevo = await res.json();\n        this.productos.push(nuevo);\n      }\n      this.modal.hide();\n      this.form = {\n        nombre: '',\n        precio: ''\n      };\n      this.editando = null;\n    },\n    async eliminar(id) {\n      await fetch(`${API}/${id}`, {\n        method: 'DELETE'\n      });\n      this.productos = this.productos.filter(p => p.id !== id);\n    }\n  }\n};","map":{"version":3,"names":["Modal","defineRule","validate","value","toString","trim","API","data","productos","form","nombre","precio","errores","editando","modal","created","res","fetch","json","mounted","document","getElementById","methods","abrirModal","producto","id","show","guardar","resultNombre","resultPrecio","valid","errors","method","headers","body","JSON","stringify","actualizado","index","findIndex","p","nuevo","push","hide","eliminar","filter"],"sources":["C:\\Users\\SCIS-PC18\\Desktop\\DAWYSO-A\\Extensiones y retos\\src\\components\\ProductoComponent.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-4\">\r\n    <h3>Gestión de Productos</h3>\r\n\r\n    <button class=\"btn btn-success mb-3\" @click=\"abrirModal()\">+ Agregar Producto</button>\r\n\r\n    <table class=\"table table-striped\">\r\n      <thead>\r\n        <tr><th>Nombre</th><th>Precio</th><th>Acciones</th></tr>\r\n      </thead>\r\n      <tbody>\r\n        <tr v-for=\"p in productos\" :key=\"p.id\">\r\n          <td>{{ p.nombre }}</td>\r\n          <td>{{ p.precio }}</td>\r\n          <td>\r\n            <button @click=\"abrirModal(p)\" class=\"btn btn-warning btn-sm me-2\">Editar</button>\r\n            <button @click=\"eliminar(p.id)\" class=\"btn btn-danger btn-sm\">Eliminar</button>\r\n          </td>\r\n        </tr>\r\n      </tbody>\r\n    </table>\r\n\r\n    <!-- Modal -->\r\n    <div class=\"modal fade\" id=\"productoModal\" tabindex=\"-1\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">{{ editando ? 'Editar Producto' : 'Nuevo Producto' }}</h5>\r\n            <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <div class=\"mb-2\">\r\n              <input v-model=\"form.nombre\" class=\"form-control\" :class=\"{'is-invalid': errores.nombre}\" placeholder=\"Nombre\" />\r\n              <div class=\"invalid-feedback\">{{ errores.nombre }}</div>\r\n            </div>\r\n            <div class=\"mb-2\">\r\n              <input v-model=\"form.precio\" class=\"form-control\" :class=\"{'is-invalid': errores.precio}\" placeholder=\"Precio\" type=\"number\" />\r\n              <div class=\"invalid-feedback\">{{ errores.precio }}</div>\r\n            </div>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" @click=\"guardar\">Guardar</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Modal } from 'bootstrap'\r\nimport { defineRule, validate } from 'vee-validate'\r\n\r\ndefineRule('required', value => {\r\n  if (!value || !value.toString().trim()) return 'Este campo es obligatorio'\r\n  return true\r\n})\r\n\r\ndefineRule('minPrice', value => {\r\n  if (value <= 0) return 'El precio debe ser mayor a 0'\r\n  return true\r\n})\r\n\r\nconst API = 'https://6a1aebbbbc2f94475492cebb.mockapi.io/Productos'\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      productos: [],\r\n      form: { nombre: '', precio: '' },\r\n      errores: { nombre: '', precio: '' },\r\n      editando: null,\r\n      modal: null\r\n    }\r\n  },\r\n  async created() {\r\n    const res = await fetch(API)\r\n    this.productos = await res.json()\r\n  },\r\n  mounted() {\r\n    this.modal = new Modal(document.getElementById('productoModal'))\r\n  },\r\n  methods: {\r\n    abrirModal(producto = null) {\r\n      if (producto) {\r\n        this.editando = producto.id\r\n        this.form = { nombre: producto.nombre, precio: producto.precio }\r\n      } else {\r\n        this.editando = null\r\n        this.form = { nombre: '', precio: '' }\r\n      }\r\n      this.errores = { nombre: '', precio: '' }\r\n      this.modal.show()\r\n    },\r\n    async guardar() {\r\n      const resultNombre = await validate(this.form.nombre, 'required')\r\n      const resultPrecio = await validate(this.form.precio, 'required|minPrice')\r\n\r\n      this.errores.nombre = resultNombre.valid ? '' : resultNombre.errors[0]\r\n      this.errores.precio = resultPrecio.valid ? '' : resultPrecio.errors[0]\r\n\r\n      if (!resultNombre.valid || !resultPrecio.valid) return\r\n\r\n      if (this.editando) {\r\n        const res = await fetch(`${API}/${this.editando}`, {\r\n          method: 'PUT',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify(this.form)\r\n        })\r\n        const actualizado = await res.json()\r\n        const index = this.productos.findIndex(p => p.id === this.editando)\r\n        this.productos[index] = actualizado\r\n      } else {\r\n        const res = await fetch(API, {\r\n          method: 'POST',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify(this.form)\r\n        })\r\n        const nuevo = await res.json()\r\n        this.productos.push(nuevo)\r\n      }\r\n\r\n      this.modal.hide()\r\n      this.form = { nombre: '', precio: '' }\r\n      this.editando = null\r\n    },\r\n    async eliminar(id) {\r\n      await fetch(`${API}/${id}`, { method: 'DELETE' })\r\n      this.productos = this.productos.filter(p => p.id !== id)\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AAoDA,SAASA,KAAI,QAAS,WAAU;AAChC,SAASC,UAAU,EAAEC,QAAO,QAAS,cAAa;AAElDD,UAAU,CAAC,UAAU,EAAEE,KAAI,IAAK;EAC9B,IAAI,CAACA,KAAI,IAAK,CAACA,KAAK,CAACC,QAAQ,CAAC,CAAC,CAACC,IAAI,CAAC,CAAC,EAAE,OAAO,2BAA0B;EACzE,OAAO,IAAG;AACZ,CAAC;AAEDJ,UAAU,CAAC,UAAU,EAAEE,KAAI,IAAK;EAC9B,IAAIA,KAAI,IAAK,CAAC,EAAE,OAAO,8BAA6B;EACpD,OAAO,IAAG;AACZ,CAAC;AAED,MAAMG,GAAE,GAAI,uDAAsD;AAElE,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE;QAAEC,MAAM,EAAE,EAAE;QAAEC,MAAM,EAAE;MAAG,CAAC;MAChCC,OAAO,EAAE;QAAEF,MAAM,EAAE,EAAE;QAAEC,MAAM,EAAE;MAAG,CAAC;MACnCE,QAAQ,EAAE,IAAI;MACdC,KAAK,EAAE;IACT;EACF,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAMC,GAAE,GAAI,MAAMC,KAAK,CAACX,GAAG;IAC3B,IAAI,CAACE,SAAQ,GAAI,MAAMQ,GAAG,CAACE,IAAI,CAAC;EAClC,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACL,KAAI,GAAI,IAAId,KAAK,CAACoB,QAAQ,CAACC,cAAc,CAAC,eAAe,CAAC;EACjE,CAAC;EACDC,OAAO,EAAE;IACPC,UAAUA,CAACC,QAAO,GAAI,IAAI,EAAE;MAC1B,IAAIA,QAAQ,EAAE;QACZ,IAAI,CAACX,QAAO,GAAIW,QAAQ,CAACC,EAAC;QAC1B,IAAI,CAAChB,IAAG,GAAI;UAAEC,MAAM,EAAEc,QAAQ,CAACd,MAAM;UAAEC,MAAM,EAAEa,QAAQ,CAACb;QAAO;MACjE,OAAO;QACL,IAAI,CAACE,QAAO,GAAI,IAAG;QACnB,IAAI,CAACJ,IAAG,GAAI;UAAEC,MAAM,EAAE,EAAE;UAAEC,MAAM,EAAE;QAAG;MACvC;MACA,IAAI,CAACC,OAAM,GAAI;QAAEF,MAAM,EAAE,EAAE;QAAEC,MAAM,EAAE;MAAG;MACxC,IAAI,CAACG,KAAK,CAACY,IAAI,CAAC;IAClB,CAAC;IACD,MAAMC,OAAOA,CAAA,EAAG;MACd,MAAMC,YAAW,GAAI,MAAM1B,QAAQ,CAAC,IAAI,CAACO,IAAI,CAACC,MAAM,EAAE,UAAU;MAChE,MAAMmB,YAAW,GAAI,MAAM3B,QAAQ,CAAC,IAAI,CAACO,IAAI,CAACE,MAAM,EAAE,mBAAmB;MAEzE,IAAI,CAACC,OAAO,CAACF,MAAK,GAAIkB,YAAY,CAACE,KAAI,GAAI,EAAC,GAAIF,YAAY,CAACG,MAAM,CAAC